{
  "Paths": {
    "DataDir": "./extracted_data",
    "ParquetDir": "./parquet_data",
    "OutputDir": "./cnpj_shards",
    "DownloadDir": "./downloads"
  },
  "Rclone": {
    "RemoteBase": "Opencnpj:opencnpj/files",
    "Transfers": 4,
    "MaxConcurrentUploads": 1,
    "BufferSize": "16M",
    "UploadVerificationRetries": 3,
    "UploadVerificationDelaySeconds": 15
  },
  "DuckDb": {
    "UseInMemory": false,
    "ThreadsPragma": 1,
    "MemoryLimit": "4GB",
    "EngineThreads": 1,
    "PreserveInsertionOrder": false,
    "PartitionedWriteMaxOpenFiles": 16
  },
  "Shards": {
    "PrefixLength": 3,
    "RemoteDir": "shards",
    "MaxParallelProcessing": 8,
    "QueryBatchSize": 4
  },
  "Downloader": {
    "ParallelDownloads": 2,
    "PublicShareRoot": "https://arquivos.receitafederal.gov.br/public.php/dav/files/YggdBLfdninEJX9/"
  },
  "CnoIntegration": {
    "Enabled": true,
    "PublicShareRoot": "https://arquivos.receitafederal.gov.br/public.php/dav/files/gn672Ad4CF8N6TK/Dados/Cadastros/CNO/",
    "ZipFileName": "cno.zip",
    "RefreshHours": 24
  }
}
